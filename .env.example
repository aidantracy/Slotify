# Copy this file to .env and adjust as needed.

# Local development uses a plain SQLite file in the project root.
DATABASE_URL=file:slotify.db

# For production on Turso (https://turso.tech), set these instead:
# DATABASE_URL=libsql://your-database-name.turso.io
# DATABASE_AUTH_TOKEN=your-turso-auth-token

# Secret used to sign login tokens (JWT). Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# Email (optional). If SMTP_HOST is left unset, Slotify uses a free Ethereal
# test inbox and logs a preview URL instead of sending real email — great for
# local development. To send real email, fill these in (e.g. a Gmail app
# password, SendGrid, Mailgun, etc.).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=Slotify <no-reply@yourdomain.com>

# Optional: override the backend port (defaults to 3000)
# PORT=3000
