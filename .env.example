# Copy this file to .env and adjust as needed.

# Local development uses a plain SQLite file in the project root.
DATABASE_URL=file:slotify.db

# For production on Turso (https://turso.tech), set these instead:
# DATABASE_URL=libsql://your-database-name.turso.io
# DATABASE_AUTH_TOKEN=your-turso-auth-token

# Optional: override the backend port (defaults to 3000)
# PORT=3000
